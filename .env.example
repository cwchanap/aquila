# Database Configuration — Prisma Postgres (PostgreSQL-compatible)
# Connection string from Vercel → Storage → your Prisma Postgres store.
DATABASE_URL=postgres://USER:PASSWORD@db.prisma.io:5432/postgres?sslmode=require

# Allow self-signed SSL certificates (set "true" only for non-production self-signed certs)
# DB_ALLOW_SELF_SIGNED=false

# Maximum connections for the PostgreSQL pool (default 10; lower for serverless)
# DB_POOL_MAX=10

# Local development (optional local Postgres)
# DATABASE_URL=postgres://postgres@localhost:5432/aquila

# ── Better Auth ──────────────────────────────────────────────────────────────
# In production only THREE secrets are required (the URL/origin config is
# deduced from the request hostname — see below):
#   - GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET  (Google OAuth client)
#   - BETTER_AUTH_SECRET                        (session-cookie signing key)
# Generate a secret with: openssl rand -base64 32

# Google OAuth (Better Auth social provider)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Session signing key. Required in production. Leave blank locally (a throwaway
# dev secret is used). Generate: openssl rand -base64 32
# BETTER_AUTH_SECRET=

# BETTER_AUTH_URL and TRUSTED_ORIGINS are OPTIONAL overrides. On Vercel they are
# auto-derived from VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL / VERCEL_BRANCH_URL,
# so you normally do not set them. Set them only for non-Vercel hosts or to pin a
# custom value. Locally they default to http://localhost:5090.
# BETTER_AUTH_URL=https://your-domain.example.com
# TRUSTED_ORIGINS=https://your-domain.example.com
