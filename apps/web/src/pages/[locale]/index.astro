---
import MainLayout from '../../layouts/main.astro';
// Component Imports
import MainMenu from '../../components/MainMenu.svelte';
import { t as translate } from '../../lib/utils';

const locale = Astro.params.locale || 'en';
const t = (key: string) => translate(locale, key);
---

<MainLayout title={t("menu.title")}>
	<MainMenu client:load locale={Astro.params.locale || 'en'} />

	<script>
		// Handle language preference persistence
		document.addEventListener('DOMContentLoaded', () => {
			let savedLanguage: string | null = null;
			try {
				savedLanguage = localStorage.getItem('aquila:language');
			} catch {
				// localStorage may be unavailable (e.g. private browsing)
			}

			if (!savedLanguage) return;

			const isOnZh = window.location.pathname.startsWith('/zh');
			const isOnEn = window.location.pathname.startsWith('/en');

			// If user prefers Chinese but is on English, redirect
			if (savedLanguage === 'zh' && isOnEn) {
				window.location.href = '/zh';
				return;
			}

			// If user prefers English but is on Chinese, redirect
			if (savedLanguage === 'en' && isOnZh) {
				window.location.href = '/en';
				return;
			}
		});
	</script>
</MainLayout>
