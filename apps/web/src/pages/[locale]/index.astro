---
import MainLayout from '../../layouts/main.astro';
// Component Imports
import MainMenu from '../../components/MainMenu.svelte';
import AuthDegradedBanner from '../../components/AuthDegradedBanner.astro';
import { getSessionUser } from '../../lib/auth-utils.js';
import { t as translate } from '../../lib/utils';

interface Props {
  locale?: string;
}

const locale = (Astro.props.locale as string | undefined) || Astro.params.locale || 'en';
const t = (key: string) => translate(locale, key);

// Resolve the session server-side so the menu renders the authenticated state
// in the initial HTML — avoids a flash of the unauthenticated (login) state
// while UserStatus would otherwise client-fetch /api/auth/get-session.
const sessionResult = await getSessionUser(Astro.request);
const user = sessionResult.status === 'ok' ? sessionResult.user : null;
const authFailed = sessionResult.status === 'error';
---

<MainLayout title={t("menu.title")}>
	{authFailed && <AuthDegradedBanner message={t('auth.degradedBanner')} />}
	<MainMenu client:load locale={locale} user={user} />

	<script>
		// Handle language preference persistence
		document.addEventListener('DOMContentLoaded', () => {
			let savedLanguage: string | null = null;
			try {
				savedLanguage = localStorage.getItem('aquila:language');
			} catch {
				// localStorage may be unavailable (e.g. private browsing)
			}

			if (!savedLanguage) return;

			const isOnZh = window.location.pathname.startsWith('/zh');
			const isOnEn = window.location.pathname.startsWith('/en');

			// If user prefers Chinese but is on English, redirect
			if (savedLanguage === 'zh' && isOnEn) {
				window.location.href = '/zh';
				return;
			}

			// If user prefers English but is on Chinese, redirect
			if (savedLanguage === 'en' && isOnZh) {
				window.location.href = '/en';
				return;
			}
		});
	</script>
</MainLayout>
