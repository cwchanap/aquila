---
import MainLayout from '../../../layouts/main.astro';
import OceanBackground from '../../../components/OceanBackground.astro';
import UserStatus from '../../../components/UserStatus.svelte';
import { StoryId } from '../../../lib/story-types.js';
import { getSessionUser } from '../../../lib/auth-utils.js';
import { t as translate } from '../../../lib/utils';

interface Props {
  locale?: string;
}

const locale = (Astro.props.locale as string | undefined) || Astro.params.locale || 'en';
const t = (key: string) => translate(locale, key);

// Try to get session
let user = null;
try {
  user = await getSessionUser(Astro.request);
} catch (error) {
  console.log('Auth session error:', error instanceof Error ? error.message : 'Unknown error');
}
---

<MainLayout title={t("stories.title")}>
  <OceanBackground>

    <!-- Back button — refined glass pill -->
    <a
      href={`/${locale}/`}
      aria-label={t("common.backLabel")}
      class="absolute top-6 left-6 z-20 flex items-center gap-2 px-4 py-2.5 rounded-full bg-white/10 hover:bg-white/20 backdrop-blur-md border border-white/20 hover:border-white/40 text-white/80 hover:text-white transition-all duration-300 motion-safe:hover:scale-105 text-sm font-light tracking-wide"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      <span>{t("common.back")}</span>
    </a>

    <!-- User status -->
    <UserStatus client:load user={user} currentLocale={locale} />

    <!-- Main content -->
    <div class="min-h-screen flex flex-col items-center justify-center px-6 py-24">

      <!-- Header -->
      <div class="text-center mb-12 motion-safe:animate-[fadeSlideDown_0.7s_ease_forwards]">
        <!-- Ambient divider above -->
        <div class="flex items-center justify-center gap-3 mb-6">
          <div class="h-px w-16 bg-gradient-to-r from-transparent to-cyan-300/50"></div>
          <!-- Subtle accent: slow-drifting tide mark -->
          <div class="w-2 h-2 rounded-full bg-cyan-300/60 motion-safe:animate-[tidePulse_4s_ease-in-out_infinite]"></div>
          <div class="h-px w-16 bg-gradient-to-l from-transparent to-cyan-300/50"></div>
        </div>

        <h1 class="text-4xl sm:text-5xl font-serif font-bold text-white/95 tracking-tight drop-shadow-lg mb-3">
          {t("stories.heading")}
        </h1>
        <p class="text-white/50 text-sm tracking-[0.25em] uppercase font-light">
          {t("stories.chooseYourAdventure")}
        </p>
      </div>

      <!-- Story Cards Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full max-w-3xl">

        <!-- Train Adventure Card -->
        <a
          href={`/${locale}/reader?story=${StoryId.TRAIN_ADVENTURE}`}
          class="story-card group block rounded-2xl overflow-hidden motion-safe:animate-[fadeSlideUp_0.6s_0.1s_ease_both]"
        >
          <div class="relative h-full p-8 bg-white/[0.08] hover:bg-white/[0.14] backdrop-blur-xl border border-white/15 hover:border-cyan-300/40 rounded-2xl transition-all duration-500 motion-safe:group-hover:-translate-y-1 motion-safe:group-hover:shadow-[0_20px_60px_rgba(103,232,249,0.15)]">
            <!-- Chapter emblem -->
            <div class="mb-5 flex items-start justify-between">
              <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-cyan-400/30 to-blue-500/30 border border-cyan-300/30 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-cyan-300/90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 17h8m-8 0a2 2 0 01-2-2V7a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2m-8 0H6m10 0h2M9 11h6M9 7h2" />
                </svg>
              </div>
              <!-- Arrow hint -->
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white/20 motion-safe:transition-all motion-safe:duration-300 motion-safe:group-hover:text-cyan-300/70 motion-safe:group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </div>

            <!-- Story title -->
            <h2 class="text-xl font-serif font-semibold text-white/90 mb-2 leading-snug group-hover:text-white transition-colors duration-300">
              {t("stories.trainAdventure")}
            </h2>

            <!-- Descriptor — aria-hidden so accessible name stays as the title -->
            <p class="text-white/45 text-sm font-light leading-relaxed group-hover:text-white/60 transition-colors duration-300" aria-hidden="true">
              {t("stories.trainAdventureDesc")}
            </p>

            <!-- Bottom shimmer line -->
            <div class="mt-6 h-px bg-gradient-to-r from-cyan-400/0 via-cyan-400/30 to-cyan-400/0 motion-safe:scale-x-0 motion-safe:group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
          </div>
        </a>

        <!-- Don't Save Me Before Midnight Card -->
        <a
          href={`/${locale}/reader?story=${StoryId.DONT_SAVE_ME_BEFORE_MIDNIGHT}`}
          class="story-card group block rounded-2xl overflow-hidden motion-safe:animate-[fadeSlideUp_0.6s_0.25s_ease_both]"
        >
          <div class="relative h-full p-8 bg-white/[0.08] hover:bg-white/[0.14] backdrop-blur-xl border border-white/15 hover:border-indigo-300/40 rounded-2xl transition-all duration-500 motion-safe:group-hover:-translate-y-1 motion-safe:group-hover:shadow-[0_20px_60px_rgba(165,180,252,0.12)]">
            <!-- Chapter emblem -->
            <div class="mb-5 flex items-start justify-between">
              <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-400/30 to-violet-500/30 border border-indigo-300/30 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-indigo-200/90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                </svg>
              </div>
              <!-- Arrow hint -->
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white/20 motion-safe:transition-all motion-safe:duration-300 motion-safe:group-hover:text-indigo-300/70 motion-safe:group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </div>

            <!-- Story title -->
            <h2 class="text-xl font-serif font-semibold text-white/90 mb-2 leading-snug group-hover:text-white transition-colors duration-300">
              {t("stories.dontSaveMeBeforeMidnight")}
            </h2>

            <!-- Descriptor — aria-hidden -->
            <p class="text-white/45 text-sm font-light leading-relaxed group-hover:text-white/60 transition-colors duration-300" aria-hidden="true">
              {t("stories.dontSaveMeBeforeMidnightDesc")}
            </p>

            <!-- Bottom shimmer line -->
            <div class="mt-6 h-px bg-gradient-to-r from-indigo-400/0 via-indigo-400/30 to-indigo-400/0 motion-safe:scale-x-0 motion-safe:group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
          </div>
        </a>

      </div>

    </div>

  </OceanBackground>
</MainLayout>

<style is:global>
  @keyframes fadeSlideDown {
    from { opacity: 0; transform: translateY(-16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes tidePulse {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50%       { opacity: 0.9; transform: scale(1.4); }
  }

  @media (prefers-reduced-motion: reduce) {
    /* Scope to this page's own decorative animation classes only — a broad
       `[class*="animate-"]` selector would also suppress legitimate Tailwind
       `animate-*` utilities on shared components (e.g. UserStatus) rendered on
       this route. The elements above already gate animations with
       `motion-safe:`, so this is a belt-and-braces fallback for the keyframe
       helpers defined in this block. */
    .story-card,
    [class*="fadeSlide"],
    [class*="tidePulse"] {
      animation: none !important;
    }
  }
</style>

<script>
  // Removed automatic redirect for guest users to allow access to story config page
  // Users can now choose whether to play or configure their stories
</script>
